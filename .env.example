# ── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/contentbuilder

# ── Service URLs / ports ──────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# Exposed to the Next.js browser bundle (must mirror API_URL).
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Storage ───────────────────────────────────────────────────────────────────
# disk now; a CloudinaryStorageProvider drops in later with no schema change.
STORAGE_PROVIDER=disk
STORAGE_DIR=./storage

# ── AI (OPTIONAL) ───────────────────────────────────────────────────────────────
# The entire app works with these unset — AI buttons simply disable.
# ANTHROPIC_API_KEY=
# Vision-capable model: brand role/vibe pass (once per business).
# ANTHROPIC_MODEL=claude-opus-4-8
# Smaller/cheaper text model: opt-in "draft from a paragraph" parse.
# ANTHROPIC_MODEL_SMALL=claude-haiku-4-5-20251001
