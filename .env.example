# ── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/contentbuilder

# ── Service URLs / ports ──────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# Exposed to the Next.js browser bundle (must mirror API_URL).
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Web UI auth (OPTIONAL) ──────────────────────────────────────────────────────
# Set to enable HTTP Basic auth on the web UI (leave empty to disable). The API on :4000 is not gated by this — keep it network-isolated for full protection.
APP_PASSWORD=

# ── Storage ───────────────────────────────────────────────────────────────────
# disk now; a CloudinaryStorageProvider drops in later with no schema change.
STORAGE_PROVIDER=disk
STORAGE_DIR=./storage

# ── AI (OPTIONAL) ───────────────────────────────────────────────────────────────
# The entire app works with these unset — AI buttons simply disable. Recommended
# tiering: Opus designs, Sonnet does vision/critique, Haiku parses.
# ANTHROPIC_API_KEY=
# Vision + critique tier (brand role/vibe pass, layout critique). Sonnet-class.
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Mechanical/parse tier: shorthand-style paragraph→units, simple drafts. Haiku-class.
# ANTHROPIC_MODEL_SMALL=claude-haiku-4-5-20251001
# Free-canvas + judgment tier (captions, campaigns, free drafts). Sonnet-class.
# ANTHROPIC_MODEL_FREE=claude-sonnet-4-6
# DESIGN-critical tier: the Brand Design Director (per-brand layouts + authored
# vector backgrounds). Opus-class; falls back down the stack if unset.
# ANTHROPIC_MODEL_DESIGN=claude-opus-4-8

# Stock photos (optional): free key at https://www.pexels.com/api/ — when set,
# AI drafts place fitting stock photos automatically instead of leaving
# image placeholders.
PEXELS_API_KEY=
